# Author: Ingeborg Waernbaum
# Date: 2023-11-08
# This code presents an example on multivariate dependency structures in Example 3 with a
# deterministic relationships between the variables that cannot be presented as a DAG.
# Generate data with a binary treatment, continuous first mediator and dichotomized subsequent mediator
# no confounding
# Load required libraries
library(mvtnorm)
library(bnlearn)
# Generate data -----------------------------------------------------------
# Set a seed for reproducibility
set.seed(2911)
# Set the sample size
n <- 1000000
# Define confounders c1, c2 with a deterministic relationship
errors <- rmvnorm(n, sigma = diag(3))
# Generate confounders
c1 <- errors[, 1]
c2 <- errors[ , 2]
c3 <- c1 + c2
c4 <- c1 - c2
# Generate a binary treatment that depends on c1 and c2
a <- rbinom(n, size = 1, prob = plogis(c3))
# Generate potential outcomes
y1 <- 4 + c4 + errors[, 2]
y0 <- 2 + c4 + errors[, 3]
# Generate the observed outcome
y <- ifelse(a == 1, y1, y0)
# Average treatment effect is equal to total effect of Ey1 - Ey0 = 4 + Ec1 - (2 + Ec2) = 4 - 2  = 2
mean(y1) - mean(y0)
# Estimate DAGs from the observed and potential outcomes data -------------
# Estimate a graph from the observed data
df <- as.data.frame(cbind(a, c1, c2, c3, c4, y))
cpdag <- pc.stable(df)
# Plot the graph to visualize the inferred causal relationships
plot(cpdag)
# Check ignorability ------------------------------------------------------
ci.test(y0, as.numeric(a), data.frame(c1, c2, c3, c4)) # y0 is independent of a given c1, c2: weak unconfoundedness is fulfilled
ci.test(y1, as.numeric(a), data.frame(c1, c2, c3, c4)) # y1 is independent of a given c1, c2: weak unconfoundedness is fulfilled
ci.test(y0, as.numeric(a), data.frame(c1, c2))
# Average causal effect can be consistently estimated by a linear regression: --------
lm(y ~ a + c1 + c2)
lm(y ~ a )
lm(y ~ a +c1+ c2+ c3 + c4)
summary(lm(y ~ a +c1+ c2+ c3 + c4))
# Estimate DAGs from the observed and potential outcomes data -------------
# Estimate a graph from the observed data
df <- as.data.frame(cbind(c1, c2, c3, c4))
cpdag <- pc.stable(df)
# Plot the graph to visualize the inferred causal relationships
plot(cpdag)
# Estimate DAGs from the observed and potential outcomes data -------------
# Estimate a graph from the observed data
df <- as.data.frame(cbind(a, c1, c2, c3, c4, y1))
cpdag <- pc.stable(df)
# Plot the graph to visualize the inferred causal relationships
plot(cpdag)
# Estimate DAGs from the observed and potential outcomes data -------------
# Estimate a graph from the observed data
df <- as.data.frame(cbind(a, c2, c1, c3, c4, y1))
cpdag <- pc.stable(df)
# Plot the graph to visualize the inferred causal relationships
plot(cpdag)
lm(y ~ a )
